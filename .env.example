# === Сервер ===
NODE_ENV=development
PORT=3000

# === База даних (PostgreSQL) ===
POSTGRES_USER=taskmgr
POSTGRES_PASSWORD=changeme_in_prod
POSTGRES_DB=taskmgr
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Повна URL для Prisma (формується з полів вище)
DATABASE_URL=postgresql://taskmgr:changeme_in_prod@localhost:5432/taskmgr?schema=public

# === Redis (кеш) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# === Безпека ===
JWT_SECRET=please_change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# === Логування ===
LOG_LEVEL=info
