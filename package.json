{
  "name": "task-manager",
  "version": "1.0.0",
  "description": "Веб-додаток «Менеджер задач» — курсова робота, сучасна шарувата архітектура (Clean Architecture, Repository, DTO, DI, SOLID).",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint \"{src,tests}/**/*.ts\"",
    "lint:fix": "eslint \"{src,tests}/**/*.ts\" --fix",
    "format": "prettier --write \"{src,tests}/**/*.ts\"",
    "test": "jest --testPathIgnorePatterns=tests/integration --coverage --runInBand --forceExit",
    "test:unit": "jest --testPathIgnorePatterns=tests/integration --coverage --runInBand --forceExit",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand --forceExit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "test:ci": "jest --testPathIgnorePatterns=tests/integration --coverage --runInBand --forceExit --ci"
  },
  "author": "Загорянський М. В., ФеП-31",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "^17.4.2",
    "express": "4.21.1",
    "helmet": "8.0.0",
    "ioredis": "5.4.1",
    "jsonwebtoken": "9.0.2",
    "pino": "9.5.0",
    "pino-http": "10.3.0",
    "pino-pretty": "^13.1.3",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "22.9.0",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "8.14.0",
    "@typescript-eslint/parser": "8.14.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "jest": "29.7.0",
    "jest-junit": "^17.0.0",
    "prettier": "3.3.3",
    "prisma": "5.22.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
