{
  "name": "task-manager",
  "version": "2.0.0",
  "description": "Менеджер задач — In-Memory архітектура, GoF патерни (Strategy, Observer), SOLID, 200+ тестів, CI/CD з SonarQube. Курсова робота ФеП-31.",
  "author": "Загорянський М. В., ФеП-31",
  "license": "MIT",
  "scripts": {
    "test": "jest --coverage --runInBand",
    "test:unit": "jest --testPathPattern=tests/unit --coverage --runInBand",
    "test:ci": "jest --coverage --runInBand --ci --reporters=default --reporters=jest-junit",
    "lint": "eslint \"{src,tests}/**/*.ts\"",
    "lint:fix": "eslint \"{src,tests}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "22.9.0",
    "@typescript-eslint/eslint-plugin": "8.14.0",
    "@typescript-eslint/parser": "8.14.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "jest": "29.7.0",
    "jest-junit": "16.0.0",
    "ts-jest": "29.2.5",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
