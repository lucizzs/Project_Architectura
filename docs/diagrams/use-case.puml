  usecase "UC-05: Редагування проєкту" as UC05
  usecase "UC-06: Видалення проєкту" as UC06
  usecase "UC-07: Додавання учасника" as UC07
  usecase "UC-08: Видалення учасника" as UC08
  usecase "UC-09: Перегляд учасників" as UC09

