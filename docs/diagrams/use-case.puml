  usecase "UC-11: Редагування завдання" as UC11
  usecase "UC-12: Зміна статусу" as UC12
  usecase "UC-13: Призначення виконавця" as UC13
  usecase "UC-14: Пошук та фільтрація" as UC14
  usecase "UC-15: Видалення завдання" as UC15
  usecase "UC-16: Пріоритизація (Strategy)" as UC16
  usecase "UC-17: Нарахування штрафів (Strategy)" as UC17
